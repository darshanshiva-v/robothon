<mujoco>
   <option gravity="0 0 -9.81"/>

    <worldbody>
        <geom type="plane" size="2 2 0.1"/>

        <!-- Base -->
        <body name="base" pos="0 0 0">
           <joint type="hinge" axis="0 0 1" damping="2"/>
            <inertial pos="0 0 0" mass="1" diaginertia="0.01 0.01 0.01"/>

            <!-- Link1 -->
            <body name="link1" pos="0 0 0.1">
                <joint type="hinge" axis="0 1 0"/>
                <inertial pos="0 0 0.1" mass="0.5" diaginertia="0.005 0.005 0.005"/>
                <geom type="capsule" size="0.02 0.2"/>

                <!-- Link2 -->
                <body name="link2" pos="0 0 0.2">
                    <joint type="hinge" axis="0 1 0"/>
                    <inertial pos="0 0 0.1" mass="0.5" diaginertia="0.005 0.005 0.005"/>
                    <geom type="capsule" size="0.02 0.2"/>

                    <!-- Gripper -->
                    <body name="gripper" pos="0 0 0.2">
                        <inertial pos="0 0 0" mass="0.2" diaginertia="0.002 0.002 0.002"/>

                        <!-- LEFT FINGER -->
                        <body name="left_finger" pos="0.03 0 0">
                            <joint name="left_slide" type="slide" axis="-1 0 0" range="0 0.04"/>
                            <geom type="box" size="0.01 0.02 0.02" rgba="1 0 0 1"/>
                        </body>

                        <!-- RIGHT FINGER -->
                        <body name="right_finger" pos="-0.03 0 0">
                            <joint name="right_slide" type="slide" axis="1 0 0" range="0 0.04"/>
                            <geom type="box" size="0.01 0.02 0.02" rgba="1 0 0 1"/>
                        </body>
                    </body>

                </body>
            </body>
        </body>

        <!-- Glass -->
        <body name="glass" pos="0.4 0 0.1">
    <!-- glass -->
    <geom type="cylinder" size="0.05 0.1" rgba="1 1 1 0.3"/>

    <!-- water inside glass -->
    <body name="water_body" pos="0 0 0">
        <geom name="water" type="cylinder" size="0.045 0.001" rgba="0 0 1 0.6"/>
    </body>
</body>

        <!-- Bottle -->
        <body name="bottle" pos="0.2 0 0.2">
    <joint name="bottle_free" type="free"/>
    <geom type="cylinder" size="0.03 0.12" rgba="0 0 1 1"/>
</body>
    </worldbody>

    <!-- 🔥 ACTUATOR (THIS WAS MISSING) -->
    <actuator>
        <position joint="left_slide" kp="50"/>
        <position joint="right_slide" kp="50"/>
    </actuator>

</mujoco>