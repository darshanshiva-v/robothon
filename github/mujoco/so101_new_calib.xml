<mujoco model="so101">

    <compiler angle="degree" coordinate="local"/>
    <option gravity="0 0 -9.81" integrator="RK4"/>

    <worldbody>

        <!-- ROBOT BASE -->
        <body name="base" pos="0 0 0">

            <!-- JOINT 1 -->
            <joint name="joint1" type="hinge" axis="0 0 1" pos="0 0 0"/>

            <geom type="cylinder" size="0.05 0.1" rgba="0.5 0.5 0.5 1"/>

            <!-- LINK 1 -->
            <body name="link1" pos="0 0 0.1">
                <joint name="joint2" type="hinge" axis="0 1 0"/>

                <geom type="capsule" size="0.03 0.2" rgba="0.7 0.2 0.2 1"/>

                <!-- LINK 2 -->
                <body name="link2" pos="0 0 0.2">
                    <joint name="joint3" type="hinge" axis="0 1 0"/>

                    <geom type="capsule" size="0.025 0.2" rgba="0.2 0.7 0.2 1"/>

                    <!-- END EFFECTOR -->
                    <body name="end_effector" pos="0 0 0.2">

                        <!-- 🔥 CAMERA ATTACHED TO ARM -->
                        <camera name="arm_cam" pos="0 0 0.05" />

                        <!-- TOOL / GRIPPER -->
                        <geom type="sphere" size="0.03" rgba="0.2 0.2 1 1"/>

                    </body>

                </body>

            </body>

        </body>

        <!-- PLUG (RED BOX) -->
        <body name="plug" pos="0.3 0 0.05">
            <freejoint/>
            <inertial pos="0 0 0" mass="0.1" diaginertia="0.0001 0.0001 0.0001"/>
            <geom type="box" size="0.02 0.02 0.02" rgba="1 0 0 1"/>
        </body>

        <!-- SOCKET (BLUE CYLINDER) -->
        <body name="socket" pos="0.3 0.15 0.05">
            <freejoint/>
            <inertial pos="0 0 0" mass="0.1" diaginertia="0.0001 0.0001 0.0001"/>
            <geom type="cylinder" size="0.02 0.03" rgba="0 0 1 1"/>
        </body>

    </worldbody>

</mujoco>
